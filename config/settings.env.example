# ============================================================
# CONFIGURACIÓN DEL NODO MCP — NETBOOK LINUX
# Copiar este archivo a config/settings.env y completar valores
# ============================================================

# Token de acceso a GitHub (scope: repo)
GITHUB_TOKEN="ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Usuario de GitHub
GITHUB_USER="tu_usuario_github"

# Nombre del repositorio (debe coincidir con este repo)
GITHUB_REPO="netbook-mcp-node"

# Etiqueta de Issues que el nodo debe procesar
TASK_LABEL="mcp-cmd"

# Etiqueta que indica tarea en proceso
PROCESSING_LABEL="procesando"

# Intervalo de polling en segundos (recomendado: 20)
POLL_INTERVAL=20

# Timeout máximo por tarea en segundos (recomendado: 120)
TASK_TIMEOUT=120

# Directorio de logs
LOG_DIR="/var/log/mcp-node"

# Directorio de cola
QUEUE_DIR="/var/lib/mcp-node/queue"

# Directorio de binarios
BIN_DIR="/usr/local/bin"
